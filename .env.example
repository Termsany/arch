NODE_ENV=development
PORT=4000

DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173

UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=25
STORAGE_PROVIDER=local

# R2 endpoint must NOT include the bucket name.
# Correct format: https://ACCOUNT_ID.r2.cloudflarestorage.com
# Bucket name goes in R2_BUCKET.
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
R2_SIGNED_URL_EXPIRES_SECONDS=900

S3_BUCKET=
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=simulation
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_DEFAULT_COUNTRY_CODE=20

# Frontend should only receive VITE_ variables.
# Never expose database, JWT, R2, S3, or WhatsApp secrets to the frontend.
